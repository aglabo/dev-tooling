{
  "name": "@aglabo/dev-tooling",
  "version": "0.1.0",
  "description": "Shared dev tooling configurations and runners for aglabo and atsushifx repositories",
  "keywords": [
    "aglabo",
    "dev-tooling",
    "shareable-config",
    "lint",
    "ci",
    "github-actions",
    "security",
    "runner"
  ],
  "author": "atsushifx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aglabo/dev-tooling.git"
  },
  "files": [
    "configs",
    "runners",
    "bin"
  ],
  "bin": {
    "aglabo-actionlint": "bin/aglabo-actionlint",
    "aglabo-ghalint": "bin/aglabo-ghalint"
  },
  "scripts": {
    "scan:secrets": "gitleaks dir --config ./configs/gitleaks.toml . && secretlint --secretlintrc ./configs/secretlint.config.yaml **/*",
    "test:sh": "bash scripts/run-specs.sh "
  }
}
